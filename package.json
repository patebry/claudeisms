{
  "name": "claudeisms",
  "version": "0.3.1",
  "description": "Spotify Wrapped for Claude Code -- discover your most-used phrases, verbal tics, and claudeisms",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "claudeisms": "./dist/index.js"
  },
  "files": [
    "dist",
    "fonts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "wrapped",
    "stats",
    "ai",
    "anthropic",
    "llm",
    "analysis",
    "coding-assistant",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patebry/claudeisms.git"
  },
  "author": "patebryant",
  "homepage": "https://github.com/patebry/claudeisms#readme",
  "bugs": {
    "url": "https://github.com/patebry/claudeisms/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "boxen": "^8.0.1",
    "gradient-string": "^3.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
